<!DOCTYPE html>
<html data-theme="cupid" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - OnlyPaws</title>

    @inject CodeMechanic.Razorhat.ImportMap ImportMap

    @Html.Raw(ImportMap.RenderAsScripts(debug: true))

    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>

</head>
<body>
<header>
    <div class="navbar bg-rose-400 text-neutral-content">
        <span type="button" class="btn bg-rose-800 text-white text-xl">OnlyPaws
        </span>
    </div>
</header>
<div class="">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - OnlyPaws - <a asp-area="" asp-page="/Privacy">Privacy</a>
    </div>
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
