@model OnlyPaws.Shelter

<div class="card bg-base-100 shadow-md hover:shadow-xl transition-all">
    <div class="card-body">
        <div class="flex gap-4">
            <div class="avatar">
                <div class="w-12 h-12 rounded-full bg-rose-200 flex items-center justify-center text-2xl">
                    🏠
                </div>
            </div>
            <div class="flex-1">
                <h3 class="font-bold">@Model.Name</h3>
                <p class="text-sm text-base-content/70">@Model.City, @Model.State • @Model.PetCount pets available</p>

                <div class="flex gap-2 mt-3">
                    @foreach (var tag in Model.Tags)
                    {
                        <div class="badge badge-sm badge-secondary">@tag</div>
                    }
                </div>
            </div>
        </div>

        <div class="card-actions mt-4">
            <a asp-page="/Shelters/Details" asp-route-id="@Model.Id"
               class="btn btn-outline btn-sm flex-1">
                Browse @Model.Name Pets
            </a>
        </div>
    </div>
</div>
