@model OnlyPaws.Pet

<island>

    <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all w-full max-w-sm">
        <figure class="relative">
            <img src="@Model.img_url" alt="@Model.name" class="w-full h-64 object-cover" />
            <partial name="_MatchScoreBadge" model="Model.matchscore" />
        </figure>

        <div class="card-body">
            <div class="flex justify-between items-start">
                <h2 class="card-title">@Model.name</h2>
                <div class="badge badge-accent">@Model.breed</div>
            </div>

            <p class="text-sm">@Model.age • @Model.location</p>

            <partial name="_PersonalityTraits" model="Model.traits" />

            <div class="card-actions mt-6">
                <a asp-page="/Pets/Profile" asp-route-id="@Model.id"
                   class="btn btn-primary btn-block">
                    See Full Profile & Compatibility
                </a>
            </div>
        </div>
    </div>

