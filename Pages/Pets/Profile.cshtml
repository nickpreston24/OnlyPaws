@page "/Pets/Profile/{id}"
@model OnlyPaws.Pages.Pets.Profile

@{
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto p-4">
    <div class="card bg-base-100 shadow-2xl">
        <figure>
            <img src="@Model.Pet.img_url" alt="@Model.Pet.name" class="w-full h-96 object-cover" />
        </figure>

        <div class="card-body">
            <div class="flex justify-between items-center">
                <h1 class="card-title text-4xl">@Model.Pet.name</h1>
                <partial name="_MatchScoreBadge" model="Model.Pet.matchscore" />
            </div>

            <p class="text-lg">@Model.Pet.breed • @Model.Pet.age • @Model.Pet.location</p>
            <p class="mt-6 whitespace-pre-wrap">@Model.Pet.description</p>

            <!-- Personality Radar / Scores -->
            <h2 class="text-2xl font-bold mt-10 mb-4">Personality Match</h2>
            <partial name="_PersonalityRadar" model="Model.Pet.traits" />

            <div class="mt-10 flex gap-4">
                <button class="btn btn-primary flex-1">Adopt @Model.Pet.name</button>
                <button class="btn btn-outline flex-1">Save for Later</button>
            </div>
        </div>
    </div>
</div>
